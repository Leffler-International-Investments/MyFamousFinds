{
  "name": "myfamousfinds",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npx eslint .",
    "typecheck": "tsc --noEmit",
    "build:static": "NEXT_EXPORT=true next build",
    "cap:init:ios": "npx cap add ios",
    "cap:init:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "mobile:build": "npm run build:static && npx cap sync",
    "mobile:ios": "npm run mobile:build && npx cap open ios",
    "mobile:android": "npm run mobile:build && npx cap open android"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.990.0",
    "@aws-sdk/client-sns": "^3.700.0",
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/storage": "^7.12.1",
    "@types/react-dom": "^19.2.0",
    "baseline-browser-mapping": "^2.10.10",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.7.0",
    "formidable": "^3.5.4",
    "next": "^16.2.3",
    "nodemailer": "^6.9.16",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/formidable": "^3.4.6",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18 <23"
  }
}
