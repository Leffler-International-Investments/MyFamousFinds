# ============================================================
# MyFamousFinds — Environment Variables Reference
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these in Vercel Dashboard:
#   Settings → Environment Variables
# ============================================================

# ---------- Firebase Client (public, exposed to browser) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---------- Firebase Admin (server-side only) ----------
# Option A — single JSON (recommended): paste full service-account JSON
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B — split credentials (fallback if option A is not set)
FB_PROJECT_ID=
FB_CLIENT_EMAIL=
FB_PRIVATE_KEY=
FB_DATABASE_URL=

# ---------- Site URL ----------
NEXT_PUBLIC_SITE_URL=https://www.myfamousfinds.com
NEXT_PUBLIC_BASE_URL=https://www.myfamousfinds.com

# ---------- PayPal ----------
PAYPAL_ENV=sandbox
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ---------- Email / SMTP ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_DISABLED=false

# ---------- Admin / Management ----------
ADMIN_API_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_BACKDOOR_CODE=
ADMIN_SEED_KEY=
ADMIN_ACTION_KEY=
ADMIN_NOTIFICATION_EMAILS=

# ---------- Management Team Passwords ----------
MANAGEMENT_ARIEL_PASSWORD=
MANAGEMENT_DAN_PASSWORD=
MANAGEMENT_SUPER_EMAILS=

# ---------- Image Processing ----------
BACKGROUND_REMOVAL_API_KEY=

# ---------- VIP ----------
NEXT_PUBLIC_VIP_URL=
NEXT_PUBLIC_TAX_W9_URL=
