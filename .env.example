# ============================================================
# MyFamousFinds — Environment Variables Reference
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these in Vercel Dashboard:
#   Settings → Environment Variables
# ============================================================

# ---------- Firebase Client (public, exposed to browser) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---------- Firebase Admin (server-side only) ----------
# Option A — single JSON (recommended): paste full service-account JSON
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B — split credentials (fallback if option A is not set)
FB_PROJECT_ID=
FB_CLIENT_EMAIL=
FB_PRIVATE_KEY=
FB_DATABASE_URL=

# ---------- Site URL ----------
NEXT_PUBLIC_SITE_URL=https://www.myfamousfinds.com
NEXT_PUBLIC_BASE_URL=https://www.myfamousfinds.com

# ---------- PayPal ----------
PAYPAL_ENV=sandbox
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# NEXT_PUBLIC_PAYPAL_CLIENT_ID is NOT needed — checkout uses server-side redirect

# ---------- Email — AWS SES (primary) ----------
AWS_SES_FROM=Famous Finds <admin@myfamousfinds.com>
AWS_SES_REPLY_TO=Famous Finds Support <support@myfamousfinds.com>
# SUPPORT_INBOX — Where customer replies actually land.
# Set this to a REAL inbox (e.g. your Gmail) until support@myfamousfinds.com
# has a working inbound mailbox / MX records.  Used as Reply-To on all
# outbound emails and as the contact-form recipient.
SUPPORT_INBOX=

# ---------- Email — SMTP (Google Workspace fallback) ----------
# SMTP serves as a PRODUCTION FALLBACK when AWS SES is in sandbox mode or
# temporarily unavailable.  The system always tries SES first; if SES fails
# (e.g. sandbox recipient-not-verified error), it automatically falls back
# to SMTP — no code changes required.
#
# When SES is moved to production mode, SES will succeed on the first try
# and SMTP will never be reached.  You can leave SMTP configured as a
# safety net or remove it later.
#
# Google Workspace setup (admin@myfamousfinds.com):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=admin@myfamousfinds.com
#   SMTP_PASS=<Google App Password — generate at myaccount.google.com/apppasswords>
#   SMTP_FROM=Famous Finds <admin@myfamousfinds.com>
#
# To generate a Google App Password:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (must be ON)
#   2. At the bottom, click "App passwords"
#   3. Create one for "Mail" / "Other (Famous Finds)"
#   4. Use the 16-char password as SMTP_PASS (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@myfamousfinds.com
SMTP_PASS=
SMTP_FROM=Famous Finds <admin@myfamousfinds.com>

# ---------- AWS Credentials (shared by SES + SNS) ----------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_SMS_TYPE=Transactional
AWS_SNS_SENDER_ID=FamousFinds

# ---------- Admin / Management ----------
ADMIN_API_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SEED_KEY=
ADMIN_ACTION_KEY=                          # random secret for admin backfill operations (generate your own)
ADMIN_NOTIFICATION_EMAILS=                 # comma-separated; falls back to ADMIN_EMAIL if empty
CRON_SECRET=                               # optional; falls back to ADMIN_API_SECRET

# ---------- Management Team Passwords ----------
MANAGEMENT_ARIEL_PASSWORD=
MANAGEMENT_DAN_PASSWORD=
MANAGEMENT_SUPER_EMAILS=

# ---------- Image Processing ----------
# Background removal API key from rembg.com — either name works:
BACKGROUND_REMOVAL_API_KEY=
# REMBG_API_KEY=              # alternative name (also accepted)

# ---------- VIP ----------
NEXT_PUBLIC_VIP_URL=                       # optional; falls back to /vip-welcome
NEXT_PUBLIC_TAX_W9_URL=                    # optional; sellers see W9 link if set

# ---------- Analytics ----------
NEXT_PUBLIC_GA4_ID=G-0D7XZTGY27            # Google Analytics 4 measurement ID

# ---------- Promo Code (Friends & Family Access) ----------
NEXT_PUBLIC_PROMO_CODE=                        # promo code for free access (family/friends)

# ---------- UPS Shipping ----------
UPS_CLIENT_ID=                               # OAuth client ID from UPS developer portal
UPS_CLIENT_SECRET=                           # OAuth client secret from UPS developer portal
UPS_ACCOUNT_NUMBER=145DB4                    # UPS billing / shipper account number
UPS_BASE_URL=https://onlinetools.ups.com     # production base URL (no trailing slash)
UPS_TRANSACTION_SRC=myfamousfinds            # transaction source identifier

# ---------- Optional / Debug ----------
FIREBASE_STORAGE_BUCKET=                    # optional; used by image processing (falls back to NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET)
GOOGLE_CLOUD_PROJECT=                       # optional; debug endpoints only — auto-detected in most environments
