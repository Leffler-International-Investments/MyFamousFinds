// FILE: /firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public listings read; writes restricted (adjust to your flow)
    match /listings/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.sellerId == request.resource.data.sellerId;
    }

    // Orders readable by the seller who owns them
    match /orders/{id} {
      allow read: if request.auth != null && request.auth.token.sellerId == resource.data.sellerId;
      allow write: if false; // orders created server-side after checkout
    }

    match /refunds/{id} {
      allow read: if request.auth != null && request.auth.token.sellerId == resource.data.sellerId;
      allow write: if false; // refunds created by admin workflow
    }

    // If you add statements_monthly:
    match /statements_monthly/{doc} {
      allow read: if request.auth != null && request.auth.token.sellerId == resource.data.sellerId;
      allow write: if false;
    }
  }
}
